// BUG-01: Firestore Security Rules
// Deployed via: firebase deploy --only firestore:rules
// Every read/write requires authenticated user accessing only their own data

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── USER DATA ──
    // Each user can only read/write their own subcollections
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── CONFIG (broadcast messages — read by all authenticated users) ──
    match /config/{doc} {
      allow read: if request.auth != null;
      // Only admin can write — enforced by /api/admin server-side, deny all client writes
      allow write: if false;
    }

    // ── DEFAULT: deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
